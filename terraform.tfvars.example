AWS_REGION           = "us-east-1"
AWS_PROFILE          = "emojot-dev"
AWS_ROLE_ARN         = ""
AWS_ROLE_SESSION_NAME = "terraform-local-session"
project_name         = "aws-native-fim"
environment          = "demo"
vpc_cidr             = "172.20.0.0/16"
public_subnet_cidrs  = ["172.20.0.0/24", "172.20.1.0/24"]
instance_type        = "t3.micro"
asg_min_size         = 0
asg_desired_capacity = 1
asg_max_size         = 2

# Keep false for the cheapest demo path if Security Hub is already enabled or
# if you only want to create baselines in S3. Set true to let Terraform enable it.
enable_security_hub = false
